# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model routing — cost-aware
MODEL_CHEAP=openai/gpt-4o-mini          # query rewrite, critic checks, memory summaries
MODEL_STRONG=openai/gpt-4o              # final synthesis
MODEL_EMBED=openai/text-embedding-3-small

# Server
PORT=3000
NODE_ENV=development

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# ChromaDB
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=veritas_corpus
CHROMA_MEMORY_COLLECTION=veritas_memory

# Retrieval thresholds
RETRIEVAL_CONFIDENCE_THRESHOLD=0.45
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5

# Agent loop
AGENT_MAX_ITERATIONS=5
TOOL_OUTPUT_MAX_TOKENS=500

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Logging
LOG_LEVEL=info
