# ── LLM Providers ─────────────────────────────────────────────────────────────
# Anthropic — all completions (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter — embeddings only, Anthropic has no embeddings API (required)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Tavily — real web search (required)
TAVILY_API_KEY=your_tavily_api_key_here

# ── Models ────────────────────────────────────────────────────────────────────
MODEL_CHEAP=claude-haiku-4-5-20251001
MODEL_STRONG=claude-haiku-4-5-20251001
MODEL_EMBED=openai/text-embedding-3-small

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=veritas_corpus
CHROMA_MEMORY_COLLECTION=veritas_memory

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_CONFIDENCE_THRESHOLD=0.45
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5

# ── Agent loop ────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=5
TOOL_OUTPUT_MAX_TOKENS=500

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Semantic cache ────────────────────────────────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MIN_CONFIDENCE=0.35
SEMANTIC_CACHE_TTL_SECONDS=3600

# ── Guardrails ────────────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
GUARDRAILS_PII_ENABLED=true
GUARDRAILS_INJECTION_ENABLED=true
GUARDRAILS_CONTENT_ENABLED=true
GUARDRAILS_INJECTION_THRESHOLD=0.7

# ── Image upload / vision ingestion ───────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10

# ── Evaluation CI ─────────────────────────────────────────────────────────────
# EVAL_TIER_FILTER=1,2     # uncomment to run only specific tiers
EVAL_MIN_TIER1_PASS=4
EVAL_MIN_TIER2_PASS=3
EVAL_MIN_TIER3_PASS=2
EVAL_MIN_SCHEMA_PCT=85

# ── LangSmith — optional observability ───────────────────────────────────────
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=veritas-ai
# LANGSMITH_TRACING=true
